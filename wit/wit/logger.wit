/// Host-imported structured logging service.

interface logger {
    /// A key-value field for structured log output.
    record log-field {
        key: string,
        value: string,
    }

    /// Log at debug level.
    debug: func(msg: string, fields: list<log-field>);

    /// Log at info level.
    info: func(msg: string, fields: list<log-field>);

    /// Log at warn level.
    warn: func(msg: string, fields: list<log-field>);

    /// Log at error level.
    error: func(msg: string, fields: list<log-field>);
}
